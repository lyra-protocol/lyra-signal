# --- Solana RPC (Helius) ---
# Prefer HELIUS_API_KEY; SOLANA_RPC_URL is derived in scripts if omitted.
HELIUS_API_KEY=
SOLANA_RPC_URL=

# --- Pump.fun (PumpPortal) — official WebSocket for launches, trades, migrations ---
# Docs: https://pumpportal.fun/data-api/real-time/
# Use ONE connection; multiplex subscriptions on it (do not open many sockets).
PUMP_PORTAL_WS_URL=wss://pumpportal.fun/api/data

# Optional: PumpSwap / extended streams (requires funded wallet + key on PumpPortal)
# PUMP_PORTAL_API_KEY=

# --- Supabase (same names as lyra-ui) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_DB_PASSWORD=

# --- Azure OpenAI (Llama 4 Maverick) ---
AZURE_OPENAI_BASE_URL=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_MODEL=Llama-4-Maverick-17B-128E-Instruct-FP8
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=Llama-4-Maverick-17B-128E-Instruct-FP8

# --- DexScreener (public REST, no key) ---
# DEXSCREENER_API_BASE_URL=https://api.dexscreener.com

# --- Signal API (WebSocket live feed) ---
# Railway/Render set PORT; local dev can use SIGNAL_HTTP_PORT or PORT
PORT=3847
SIGNAL_HTTP_PORT=3847
# Per-UTC-day cap on alerts that leave the bus. Raise/lower for your product.
SIGNAL_MAX_ALERTS_PER_DAY=2000

# Rule thresholds (defaults in src/filter/rules.ts — tune without code changes)
#   SIGNAL_LARGE_USD            — min USD for whale rule (default 3500)
#   SIGNAL_MAX_EARLY_BUY_INDEX  — buys 1..N fire early_buy (default 7)
#   SIGNAL_ACCEL_RATIO          — volume acceleration ratio (default 2.8)
#   SIGNAL_VOLUME_WINDOW_MS     — rolling window (default 60000)
#   SIGNAL_VOLUME_REPEAT_MS     — min gap between volume_acceleration per mint (default 15000; 0=off)
# SIGNAL_LARGE_USD=3500
# SIGNAL_MAX_EARLY_BUY_INDEX=7
# SIGNAL_ACCEL_RATIO=2.8
# SIGNAL_VOLUME_WINDOW_MS=60000
# SIGNAL_VOLUME_REPEAT_MS=15000

# MOCK_INGEST=1
# PUMP_WORKER_ENABLED=1
# Quality gate before rules fire (default 42). Set 0 only for debugging.
# SCORE_MIN_PUMP=42

# LLM request timeout (ms) — fallback sentence if Azure is slow.
# SIGNAL_LLM_TIMEOUT_MS=12000

# Heartbeat — publishes a synthetic 'pipeline online' alert when the real
# pipeline has been silent for this long. Set to 0 to disable entirely.
# SIGNAL_HEARTBEAT_MS=300000

# Optional weight overrides — see src/scoring/algorithm/config.ts
# SCORE_ALG_BASE=15
# SCORE_ALG_ACTION_CREATE=45
# SCORE_ALG_NOTIONAL_LOG_CAP=22
# SIGNAL_DEBUG_SCORE=1
# SOL_USD_OVERRIDE=140
